# ============================================================
# DBEP-Next Backend — Environment Variables
# Copy ke .env dan isi nilai yang sesuai
# JANGAN commit file .env ke git!
# ============================================================

# --- Supabase (Development) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Database Direct Connection (untuk migration) ---
DATABASE_URL=postgresql://postgres:[password]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# --- App Settings ---
APP_NAME=DBEP-Next
APP_ENV=development
APP_SECRET_KEY=generate-random-secret-key-here
ALLOWED_ORIGINS=http://localhost:3000,https://*.app.github.dev

# --- Storage (Supabase Storage di dev, MinIO di prod) ---
STORAGE_BACKEND=supabase
STORAGE_BUCKET=dbep-documents

# --- OCR (opsional di dev) ---
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
# AZURE_DOCUMENT_INTELLIGENCE_KEY=

# --- Production only (kosongkan di dev) ---
# KEYCLOAK_URL=
# KEYCLOAK_REALM=
# KEYCLOAK_CLIENT_ID=
